{%- capture contentForQuerystring -%}
{{ content_for_header }} 
{%- endcapture -%}
{%- liquid
  layout none
  assign pageUrl = contentForQuerystring | split:'"pageurl":"' | last | split:'"' | first | split:'.myshopify.com' | last | replace:'\/','/' | replace:'%20',' ' |  replace:'\u0026','&'
  assign limit = pageUrl | split:'?' | last  | remove_first: "view=loadTab&limit="
  assign limit = limit | split:'&' | first
-%}
<div class="collection-loadTab">
  <div class="collection-tab__panel-item">
    <slider-component class="collection-tab__slider">
      <div class="carousel" data-carousel-param='' data-carousel>
        <div class="carousel-wrapper">
          <div class="swiper-container" data-carousel-container>
            <div class="swiper-wrapper row row-cols-2 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 row-cols-xxl-5">
              {%- for product in collection.products limit: limit -%}
              <div class="swiper-slide col product-item__content" data-carousel-item>
                {%- render 'index-product-item', product: product -%}
              </div>
              {%- endfor -%}
            </div>
          </div>
          <div class="carousel-navigation-content"></div>
        </div>
        <div class="carousel-pagination-content"></div>
      </div>
    </slider-component>
  </div>
</div>