{{ 'customer.css' | asset_url | stylesheet_tag }}

<div class="account-layout">
  <div class="container">
    <div class="account-content account-hub">
      <nav class="account-hub__tabs" aria-label="Hesap navigasyonu">
        <a href="#account-profile">Profil</a>
        <a href="#account-orders">Siparisler</a>
        <a href="#account-favorites">Favorilerim</a>
        <a href="#account-help">Yardim</a>
        <a href="#account-notifications">Bildirimler</a>
        <a href="#account-campaigns">Kampanyalar</a>
        <a href="#account-coupons">Kuponlar</a>
      </nav>

      <section id="account-profile" class="account-hub__card">
        <h2>Profil</h2>
        <div class="account-hub__grid">
          <div class="account-hub__info-item">
            <span class="account-hub__label">Ad Soyad</span>
            <span>{{ customer.name | default: '-' }}</span>
          </div>
          <div class="account-hub__info-item">
            <span class="account-hub__label">E-Posta</span>
            <span>{{ customer.email | default: '-' }}</span>
          </div>
          <div class="account-hub__info-item">
            <span class="account-hub__label">Telefon</span>
            <span>{{ customer.default_address.phone | default: '-' }}</span>
          </div>
          <div class="account-hub__info-item">
            <span class="account-hub__label">Varsayilan Adres</span>
            <span>
              {%- if customer.default_address -%}
                {{ customer.default_address.address1 }}, {{ customer.default_address.city }}, {{ customer.default_address.country }}
              {%- else -%}
                -
              {%- endif -%}
            </span>
          </div>
        </div>
        <div class="account-hub__actions">
          <a class="button" href="{{ routes.account_addresses_url }}">Adreslerimi Yonet</a>
          <a class="button button--secondary" href="{{ routes.account_logout_url }}">Cikis Yap</a>
        </div>
      </section>

      <section id="account-orders" class="account-hub__card">
        <h2>Siparisler</h2>
        <div class="account-orders__content">
          {% paginate customer.orders by 20 %}
            {% if customer.orders.size != 0 %}
              <table>
                <thead>
                  <tr>
                    <th class="order_number">{{ 'customer.orders.order_number' | t }}</th>
                    <th class="date">{{ 'customer.orders.date' | t }}</th>
                    <th class="payment_status">{{ 'customer.orders.payment_status' | t }}</th>
                    <th class="fulfillment_status">{{ 'customer.orders.fulfillment_status' | t }}</th>
                    <th class="total">{{ 'customer.orders.total' | t }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for order in customer.orders %}
                  <tr class="{% cycle 'odd', 'even' %} {% if order.cancelled %}cancelled_order{% endif %}">
                    <td class="td-name">{{ order.name | link_to: order.customer_url }}</td>
                    <td class="td-note"><span class="note">{{ order.created_at | date: format: 'short' }}</span></td>
                    <td class="td-authorized"><span class="status_{{ order.financial_status }}">{{ order.financial_status_label }}</span></td>
                    <td class="td-unfulfilled"><span class="status_{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span></td>
                    <td class="td-total"><span class="total money" style="font-family:'currencies'">{{ order.total_price | money }}</span></td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            {% else %}
              <div class="account-hub__empty">
                <p>Henuz siparisiniz bulunmuyor.</p>
                <a class="button" href="/collections/all">Magazaya Git</a>
              </div>
            {% endif %}
            {% include 'pagination' %}
          {% endpaginate %}
        </div>
      </section>

      <section id="account-favorites" class="account-hub__card">
        <h2>Favorilerim</h2>
        <p>Favori urunlerinizi hesap panelinden yonetebilirsiniz.</p>
        <a class="button" href="{{ routes.account_url }}#account-favorites">Favori Alanina Git</a>
      </section>

      <section id="account-help" class="account-hub__card">
        <h2>Yardim</h2>
        <p>Siparis, iade ve teslimat konularinda destek almak icin bizimle iletisime gecebilirsiniz.</p>
        {%- if shop.email != blank -%}
          <a class="button" href="mailto:{{ shop.email }}">Destek Ekibine Yaz</a>
        {%- else -%}
          <a class="button" href="{{ routes.root_url }}">Ana Sayfaya Don</a>
        {%- endif -%}
      </section>

      <section id="account-notifications" class="account-hub__card">
        <h2>Bildirimler</h2>
        <p>Yeni bir bildiriminiz bulunmuyor. Kampanya ve siparis durum guncellemeleri burada listelenir.</p>
      </section>

      <section id="account-campaigns" class="account-hub__card">
        <h2>Kampanyalar</h2>
        <p>Guncel kampanyalari incelemek icin asagidaki alana gidebilirsiniz.</p>
        <a class="button" href="/collections/all">Kampanyalari Incele</a>
      </section>

      <section id="account-coupons" class="account-hub__card">
        <h2>Kuponlar</h2>
        <p>Aktif tanimli kuponunuz bulunmuyor. Yeni kuponlar bu alanda gorunecek.</p>
      </section>
    </div>
  </div>
</div>
