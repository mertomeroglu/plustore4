<!-- /snippets/social-sharing.liquid -->
<ul class="social-sharing">
  {% if settings.share_facebook %}
    <li>
      <a target="_blank" href="//www.facebook.com/sharer.php?u={{ shop.url | append: share_permalink }}" class="btn--share share-facebook">
        {%- render 'icon-facebook' -%}
        <span class="share-title" aria-hidden="true">{{ 'general.social.links.facebook' | t }}</span>
        <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
      </a>
    </li>
  {% endif %}
  {% if settings.share_twitter %}
    <li>
      <a target="_blank" href="//twitter.com/share?text={{ share_title | url_param_escape }}&amp;url={{ shop.url | append: share_permalink }}" class="btn--share share-twitter">
        {%- render 'icon-twitter' -%}
        <span class="share-title" aria-hidden="true">{{ 'general.social.links.twitter' | t }}</span>
        <span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span>
      </a>
    </li>
  {% endif %}
  {% if settings.share_pinterest %}
    <li>
      <a target="_blank" href="//pinterest.com/pin/create/button/?url={{ shop.url | append: share_permalink }}&amp;media={{ share_image | img_url: '1024x1024' }}&amp;description={{ share_title | url_param_escape }}" class="btn--share share-pinterest">
        {%- render 'icon-pinterest' -%}
        <span class="share-title" aria-hidden="true">{{ 'general.social.links.pinterest' | t }}</span>
        <span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span>
      </a>
    </li>
  {% endif %}
</ul>



