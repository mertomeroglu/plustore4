<div class="blog-sidebar__item accordion blog-sidebar__listing is-active open">
  {%- if block.settings.title != blank -%}
    <h4 class="accordion__title">
      <span>{{ block.settings.title }}</span>
    </h4>
  {%- endif -%}
  <div class="accordion__content">
    {%- if block.settings.link_list != blank -%}
    <ul class="blog-sidebar__listing-content list-unstyled">
      {%- for link in block.settings.link_list.links -%}
      <li>
        <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}">
          {{ link.title }}
        </a>
      </li>
      {%- endfor -%}
    </ul>
    {%- endif -%}
  </div>
</div>