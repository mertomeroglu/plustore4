<div class="blog-sidebar__item accordion blog-sidebar__tag is-active open">
  {%- if block.settings.title != blank -%}
    <h4 class="accordion__title">
      <span>{{ block.settings.title }}</span>
    </h4>
  {%- endif -%}
  <div class="accordion__content">
    {% for tag in blog.tags %}
      <a href="{{ canonical_url }}/tagged/{{ tag }}" class="blog-tag-item">
        {{ tag }}
      </a>
    {%- endfor -%}
  </div>
</div>