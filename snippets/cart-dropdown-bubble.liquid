<cart-dropdown-bubble>
  <div class="cart__dropdown-content {% if cart == empty %}is-empty{% endif %}">
    <div id="cart-dropdown-bubble-product" class="cart__dropdown-product" data-cart-dropdown-bubble-product>
      {%- if cart != empty -%}
        {%- for item in cart.items -%}
          <div class="cart__dropdown-item">
            {% if item.image %}
              <img class="cart__dropdown-product-image"
                   src="{{ item.image | img_url: '140x' }}"
                   alt="{{ item.image.alt | escape }}"
                   width="70"
                   height="{{ 70 | divided_by: item.image.aspect_ratio | ceil }}"
                   loading="lazy"
                   >
            {% endif %}
            <div class="cart__dropdown-product-info">
              <h3 class="cart__dropdown-product-title">
                <a href="{{ item.product.url }}">{{ item.product.title | escape }} 
                  {%- unless item.product.has_only_default_variant -%}
                    {%- for option in item.options_with_values -%}
                  	  {% if forloop.first %}
                  		-
                  	  {% endif %}
                      {{ option.value }}
                  	  {% unless forloop.last %}
                  		/
                  	  {% endunless %}
                    {%- endfor -%}
                  {%- endunless -%}
                </a>
              </h3>
              <div class="cart__dropdown-product-price">
                {%- if item.original_price != item.final_price -%}
                  <dl class="cart-item__discounted-prices">
                    <dt class="visually-hidden">
                      {{ 'products.product.price.regular_price' | t }}
                    </dt>
                    <dd>
                      <s class="cart-item__old-price price">
                        {{ item.original_price | money }}
                      </s>
                    </dd>
                    <dt class="visually-hidden">
                      {{ 'products.product.price.sale_price' | t }}
                    </dt>
                    <dd class="price">
                      {{ item.final_price | money }}
                    </dd>
                  </dl>
                {%- else -%}
                  <span class="price">
                    {{ item.original_price | money }}
                  </span>
                {%- endif -%}
              </div>
              <div class="cart__dropdown-product-qty-wishlist">
                <span class="cart__dropdown-product-qty">
                  {{ 'sections.cart.headings.qty' | t }}: {{ item.quantity }}
                </span>
                <product-wishlist>
                  <a href="{{ item.product.url }}" data-add="{{ 'wishlist.add_to_wishlist' | t }}" data-added="{{ 'wishlist.wishlist_added' | t }}" data-wishlist-handle="{{ item.product.handle }}" class="wishlist__icon" title="{{ 'wishlist.add_to_wishlist' | t }}">
                    <span class="cs-icon icon-heart"></span>
                  </a>
                </product-wishlist>
              </div>
            </div>
            <a href="{{ item.url_to_remove }}" class="cart__dropdown-remove" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}" data-cart-dropdown-remove="{{ item.index | plus: 1 }}">
              <span class="cs-icon icon-close"></span>
            </a>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="cart__dropdown-subtotal">
      <h3 class="totals__subtotal">{{ 'sections.cart.subtotal' | t }}</h3>
      <p class="totals__subtotal-value" data-cart-modal-total>{{ cart.total_price | money_with_currency }}</p>
    </div>
    <div class="cart__dropdown-action">
      <a href="{{ routes.cart_url }}" class="button button--secondary">
        {{ 'general.cart.view' | t }}
      </a>
      <form action="{{ routes.cart_url }}" method="post">
        <button class="button button--primary" name="checkout">{{ 'sections.cart.checkout' | t }}</button>
      </form>
    </div>
    <div class="cart__dropdown-empty">
      <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
      <a href="{{ routes.all_products_collection_url }}" class="button button--secondary">
        {{ 'general.continue_shopping' | t }}
      </a>
    </div>
  </div>
</cart-dropdown-bubble>
