<div id="cart-dropdown-bubble-product" class="cart__dropdown-product">
  {%- if cart != empty -%}
  {%- for item in cart.items -%}
  <div class="cart__dropdown-item">
    {% if item.image %}
    <img class="cart__dropdown-product-image"
         src="{{ item.image | img_url: '140x' }}"
         alt="{{ item.image.alt | escape }}"
         width="70"
         height="{{ 70 | divided_by: item.image.aspect_ratio | ceil }}"
         loading="lazy"
         >
    {% endif %}
    <div class="cart__dropdown-product-info">
      <h3 class="cart__dropdown-product-title">
        <a href="{{ item.product.url }}">{{ item.product.title | escape }} 
          {%- unless item.product.has_only_default_variant -%}
          {%- for option in item.options_with_values -%}
          {% if forloop.first %}
          -
          {% endif %}
          {{ option.value }}
          {% unless forloop.last %}
          /
          {% endunless %}
          {%- endfor -%}
          {%- endunless -%}
        </a>
      </h3>
      <div class="cart__dropdown-product-price">
        {%- if item.original_price != item.final_price -%}
        <dl class="cart-item__discounted-prices">
          <dt class="visually-hidden">
            {{ 'products.product.price.regular_price' | t }}
          </dt>
          <dd>
            <s class="cart-item__old-price price">
              {{ item.original_price | money }}
            </s>
          </dd>
          <dt class="visually-hidden">
            {{ 'products.product.price.sale_price' | t }}
          </dt>
          <dd class="price">
            {{ item.final_price | money }}
          </dd>
        </dl>
        {%- else -%}
        <span class="price">
          {{ item.original_price | money }}
        </span>
        {%- endif -%}
      </div>
      <div class="cart__dropdown-product-qty-wishlist">
        <span class="cart__dropdown-product-qty">
          {{ 'sections.cart.headings.qty' | t }}: {{ item.quantity }}
        </span>
        <product-wishlist>
          <a href="{{ item.product.url }}" data-add="{{ 'wishlist.add_to_wishlist' | t }}" data-added="{{ 'wishlist.wishlist_added' | t }}" data-wishlist-handle="{{ item.product.handle }}" class="wishlist__icon" title="{{ 'wishlist.add_to_wishlist' | t }}">
            <span class="cs-icon icon-heart"></span>
          </a>
        </product-wishlist>
      </div>
    </div>
    <a href="{{ item.url_to_remove }}" class="cart__dropdown-remove" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}" data-cart-dropdown-remove="{{ item.index | plus: 1 }}">
      <span class="cs-icon icon-close"></span>
    </a>
  </div>
  {%- endfor -%}
  {%- endif -%}
</div>