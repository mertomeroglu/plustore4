<section class="reborn-footer reborn-footer-v2">
  <div class="reborn-footer-v2__payments">
    <div class="container">
      {%- if section.settings.payment_image != blank -%}
        <img
          src="{{ section.settings.payment_image | image_url: width: 860 }}"
          alt="Odeme yontemleri"
          width="860"
          height="72"
          loading="lazy"
        >
      {%- else -%}
        <img
          src="{{ section.settings.payment_image_url }}"
          alt="Odeme yontemleri"
          width="520"
          height="42"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  </div>

  <div class="reborn-footer-v2__bar"></div>

  <div class="reborn-footer-v2__trust">
    <div class="container">
      <div class="reborn-footer-v2__trust-grid">
        <div class="reborn-footer-v2__trust-item">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h11l3 4h4v6h-2a2 2 0 0 1-4 0H9a2 2 0 0 1-4 0H3V7zm2 2v6h1a2 2 0 0 1 4 0h4V9H5zm10 2v4h1a2 2 0 0 1 4 0h1v-2h-3l-2-2h-1z"/></svg>
          <h4>Ucretsiz Kargo</h4>
          <p>750 ₺ ve uzeri alisverislerde KARGO UCRETSIZ !</p>
        </div>

        <div class="reborn-footer-v2__trust-item">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l8 4v6c0 5-3.4 9.4-8 10-4.6-.6-8-5-8-10V6l8-4zm0 2.2L6 7v5c0 4 2.5 7.6 6 8.5 3.5-.9 6-4.5 6-8.5V7l-6-2.8zM11 9h2v6h-2V9zm0 7h2v2h-2v-2z"/></svg>
          <h4>Guvenli Odeme</h4>
          <p>Dunyanin en populer ve en guvenli odeme yontemleriyle odeme yapin.</p>
        </div>

        <div class="reborn-footer-v2__trust-item">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.6.6 4 .6.6 0 1 .4 1 1V21c0 .6-.4 1-1 1C10.8 22 2 13.2 2 2.5 2 1.9 2.4 1.5 3 1.5h3.5c.6 0 1 .4 1 1 0 1.4.2 2.8.6 4 .1.4 0 .8-.3 1.1l-2.2 2.2z"/></svg>
          <h4>7/24 Destek Merkezi</h4>
          <p>Sorunsuz bir alisveris deneyimi icin 7/24 destek ve cozum.</p>
        </div>

        <div class="reborn-footer-v2__trust-item">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6V3L8 7l4 4V8c2.8 0 5 2.2 5 5a5 5 0 0 1-8.5 3.5l-1.4 1.4A7 7 0 1 0 19 13c0-3.9-3.1-7-7-7z"/></svg>
          <h4>14 Gun Kosulsuz Iade</h4>
          <p>Urun ve hizmetlerimizden memnun kalmadiginiz takdirde 14 gun icinde iade imkani sunuyoruz.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="reborn-footer-v2__main">
    <div class="container">
      <div class="reborn-footer-v2__cols">
        <div>
          <h5>{{ section.settings.col1_title }}</h5>
          {%- assign col1 = linklists[section.settings.col1_menu] -%}
          {%- if col1 == blank -%}{%- assign col1 = linklists['main-menu'] -%}{%- endif -%}
          <ul>
            {%- for link in col1.links limit: 7 -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>

        <div>
          <h5>{{ section.settings.col2_title }}</h5>
          {%- assign col2 = linklists[section.settings.col2_menu] -%}
          {%- if col2 == blank -%}{%- assign col2 = linklists['main-menu'] -%}{%- endif -%}
          <ul>
            {%- for link in col2.links limit: 7 -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>

        <div>
          <h5>{{ section.settings.col3_title }}</h5>
          {%- assign col3 = linklists[section.settings.col3_menu] -%}
          {%- if col3 == blank -%}{%- assign col3 = linklists['main-menu'] -%}{%- endif -%}
          <ul>
            {%- for link in col3.links limit: 7 -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>

        <div class="reborn-footer-v2__newsletter">
          <h5>{{ section.settings.news_title }}</h5>
          <p>{{ section.settings.news_subtitle }}</p>
          {%- form 'customer', class: 'reborn-footer-v2__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" value="{{ form.email }}" placeholder="E-posta" required>
            <button type="submit">Abone ol</button>
          {%- endform -%}

          <h6>👉 Bizi Takip Edebilirsiniz</h6>
          <div class="reborn-footer-v2__social">
            <a href="https://www.trendyol.com" target="_blank" rel="noopener noreferrer"><img src="{{ 'trendyol.png' | asset_url }}" alt="Trendyol" loading="lazy"></a>
            <a href="https://www.hepsiburada.com" target="_blank" rel="noopener noreferrer"><img src="{{ 'hepsiburada.png' | asset_url }}" alt="Hepsiburada" loading="lazy"></a>
            <a href="https://www.instagram.com/plusstore7/" target="_blank" rel="noopener noreferrer"><img src="{{ 'instagram_color_icon_512.png' | asset_url }}" alt="Instagram" loading="lazy"></a>
            <a href="https://wa.me/905558802818" target="_blank" rel="noopener noreferrer"><img src="{{ 'whatsapp.png' | asset_url }}" alt="WhatsApp" loading="lazy"></a>
          </div>
        </div>
      </div>

      <div class="reborn-footer-v2__legal">
        {%- assign legal_menu = linklists[section.settings.legal_menu] -%}
        {%- if legal_menu == blank -%}{%- assign legal_menu = linklists['main-menu'] -%}{%- endif -%}
        <ul>
          {%- for link in legal_menu.links limit: 8 -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
        <p>Telif © {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
      </div>
    </div>
  </div>

  <a class="reborn-footer-v2__to-top" href="#" aria-label="Yukari cik">↑</a>
</section>

{% schema %}
{
  "name": "Reborn Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Payment logos image"
    },
    {
      "type": "text",
      "id": "payment_image_url",
      "label": "Payment image URL (fallback)",
      "default": "https://cdn.shopify.com/s/files/1/0663/4962/9483/files/logo_band_colored_1X_e4f6cbc3-8eed-4b3e-a5e6-c2710fd69b6f.png?v=1772735653"
    },
    {
      "type": "text",
      "id": "col1_title",
      "label": "Column 1 title",
      "default": "Magaza"
    },
    {
      "type": "link_list",
      "id": "col1_menu",
      "label": "Column 1 menu"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Column 2 title",
      "default": "Hesabim"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Column 2 menu"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Column 3 title",
      "default": "Yardim"
    },
    {
      "type": "link_list",
      "id": "col3_menu",
      "label": "Column 3 menu"
    },
    {
      "type": "text",
      "id": "news_title",
      "label": "Newsletter title",
      "default": "E-Bulten"
    },
    {
      "type": "textarea",
      "id": "news_subtitle",
      "label": "Newsletter subtitle",
      "default": "Kampanya, indirim ve yeni urunlerden ilk siz haberdar olun - hemen kaydolun!"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Bottom legal menu"
    }
  ]
}
{% endschema %}
