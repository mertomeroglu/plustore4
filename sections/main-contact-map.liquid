{{ 'main-contact-map.css' | asset_url | stylesheet_tag }}

<div data-section-type="map-section" class="spaced-section {{ section.settings.display }}" data-section-name="map-section">
  <div class="{{ section.settings.layout }}">
    <div class="map__container row">
      {{ section.settings.html }}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Map",
  "class": "map",
  "settings": [
	{
      "type": "select",
      "id": "display",
      "label": "Display on",
      "options": [
        {
          "value": "",
          "label": "Desktop & Mobile"
        },
        {
          "value": "d-none d-md-block",
          "label": "Desktop only"
        },
        {
          "value": "d-block d-md-none",
          "label": "Mobile only"
        }
      ],
      "default": ""
    },
	{
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "container-fluid",
          "label": "Full width"
        }
      ],
      "default": "container"
    },
    {
      "type": "html",
      "id": "html",
      "label": "Map iframe"
    }
  ],
  "presets": [
    {
      "name": "Map",
      "category": "Map"
    }
  ]
}
{% endschema %}
