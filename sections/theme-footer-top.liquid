{% if section.blocks.size > 0 %}
  <div class="top-footer top-footer--premium {{ section.settings.display }}">
    <div class="container">
      <div class="top-footer__content row">
        {% for block in section.blocks %}
          <div class="top-footer__item col-{{ block.settings.col }} col-sm-{{ block.settings.col_sm }} col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
            {% if block.settings.icon %}
              <div class="top-footer__item-icon">
                <img class="icon"
                     srcset="{% render 'bgset', image: block.settings.icon %}"
                 	 src="{% render 'srcset', image: block.settings.icon %}"
                     alt="{{ block.settings.icon.alt | escape }}"
                     width="{{ block.settings.icon.width }}"
                     height="{{ block.settings.icon.height }}"
                     >  
              </div>
            {% endif %}
            <div class="top-footer__item-content">
              {%- if block.settings.heading != blank -%}
                <p class="top-footer__item-heading">
                  {{ block.settings.heading }}
                </p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="top-footer__item-subtext">
                  {{ block.settings.subtext }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {% endfor %}
      </div>  
    </div>
  </div>
{% endif %}
