<!-- /sections/newsletter-popup.liquid -->
<link rel="stylesheet" href="{{ 'newsletter-popup.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'newsletter-popup.js' | asset_url }}" defer="defer"></script>

<newsletter-popup class="modal__layout newsletter-popup__layout" data-section="{{ section.id }}" data-timer="{{ 'now' | date: "%m/%d/%Y %T" }}" data-delay="{{ section.settings.popup_seconds }}" data-frequency="{{ section.settings.popup_days }}">
  <div class="modal__close" data-modal-close></div>
  <div class="modal__content">
    <div class="modal__header newsletter-popup__header">
      {%- if section.settings.image != blank -%}
        <div class="lazy-bg newsletter-popup__bkg" style="padding-bottom: {{ 100 | divided_by: section.settings.image.aspect_ratio }}%;">
          {%- assign preview_img = section.settings.image -%}
          <img {% render 'lazyload', preview_img: preview_img  %} />
          <span class="data-lazy-loading"></span>
        </div>
      {%- else -%}
        <img class="newsletter-popup__bkg" src="{{ '680x156.png' | asset_url }}" loading="lazy">
      {%- endif -%}
      <div class="modal__title newsletter-popup__title">
        {{ section.settings.title }}
      </div>
      <a class="modal__close-icon" data-modal-close><span class="cs-icon icon-close"></span></a>
    </div>
    <div class="modal__body newsletter-popup__body">
      {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'paragraph' -%}
          <div class="newsletter-popup__subheading" {{ block.shopify_attributes }}>{{ block.settings.paragraph }}</div>
        {%- when '@app' -%}
          {% render block %}
        {%- when 'email_form' -%}
          <div {{ block.shopify_attributes }}>
            {% form 'customer', class: 'newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="newsletter-form__field-wrapper">
                <div class="field">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="field__input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error--{{ section.id }}"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="Newsletter-success--{{ section.id }}"
                    {% endif %}
                    placeholder="{{ block.settings.placeholder }}"
                    required
                  >
                  <label class="field__label" for="NewsletterForm--{{ section.id }}">
                    {{ block.settings.placeholder }}
                  </label>
                </div>
                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
                {%- endif -%}
              </div>
              {%- if block.settings.action != blank -%}
                <button type="submit" class="newsletter__button button" name="commit">
                  {{ block.settings.action }}
                </button>
              {%- endif -%}
              {%- if form.posted_successfully? -%}
                <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</h3>
              {%- endif -%}
            {% endform %}
          </div>
        {%- when 'notification' -%}
          <div class="newsletter-popup__notification" {{ block.shopify_attributes }}>
            <div class="newsletter-notification__input">
              <input type="checkbox"
                     checked="checked"
                     id="newsletter-notification-{{ section.id }}"
                     >
              {% render 'icon-input' %}
              {% render 'icon-filter-checkmark' %}
            </div>
            {%- if block.settings.notification != blank -%}
              <label for="newsletter-notification-{{ section.id }}">
                {{ block.settings.notification }}
              </label>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
    </div>
  </div>
</newsletter-popup>
{% schema %}
{
  "name": "Newsletter popup",
  "class": "newsletter-popup",
  "tag": "section",
  "settings": [
	{
      "type": "paragraph",
      "content": "Config enable/disable on Theme settings > Genel Ayarlar > Newsletter popup"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Newsletter!"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background heading"
    },
    {
      "type": "range",
      "id": "popup_seconds",
      "label": "Delay",
      "info": "Delay is disabled in theme editor for visibility",
      "default": 5,
      "min": 1,
      "max": 60,
      "step": 1,
      "unit": "sec"
    },
    {
      "type": "range",
      "id": "popup_days",
      "label": "Frequency",
      "default": 5,
      "info": "Number of days before a dismissed popup reappears",
      "min": 1,
      "max": 30,
      "step": 1,
      "unit": "day"
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "paragraph",
		  "label": "Description",
          "default": "<p>Be the firtst in the know by getting special deals and offers sent directly to your inbox</p>"
        }
      ]
    },
    {
      "type": "email_form",
      "name": "Email form",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "placeholder",
		  "label": "Placeholder",
          "default": "Your email"
        },
		{
          "type": "text",
          "id": "action",
		  "label": "Action text",
          "default": "Sign Up"
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "notification",
      "name": "Notification",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "notification",
		  "label": "Notification",
          "default": "Don't show this popup again"
        }
      ]
    }
  ]
}
{% endschema %}