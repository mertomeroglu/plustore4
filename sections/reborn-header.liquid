<section class="reborn-header">
  <div class="reborn-announcement">
    <div class="container">
      <p>{{ section.settings.announcement_text }}</p>
    </div>
  </div>

  <div class="reborn-top">
    <div class="container reborn-top__inner">
      <a class="reborn-logo" href="{{ routes.root_url }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 220 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="220"
            height="80"
            loading="eager"
          >
        {%- else -%}
          <span>{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <search-form class="reborn-search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[unavailable_products]" value="hide">
          <input type="hidden" name="options[prefix]" value="last">
          <input class="reborn-search__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.search_placeholder }}">
          <button class="reborn-search__button" type="submit">Ara</button>
        </form>
      </search-form>

      <div class="reborn-actions">
        <a href="{{ routes.account_url }}#account-coupons">Kuponlar</a>
        <a href="{{ routes.account_url }}#account-orders">Siparis Takibi</a>
        <a href="{{ routes.account_url }}#account-favorites">Favorilerim</a>
        <a href="{{ routes.account_url }}#account-help">Yardim</a>
        <a href="#" aria-label="Para birimi">TRY <span aria-hidden="true">&#9662;</span></a>
        <a href="{{ routes.account_url }}#account-profile">Hesabim</a>
        {%- if customer -%}
          <span class="reborn-actions__or">veya</span>
          <a href="{{ routes.account_logout_url }}"><strong>Cikis yap</strong></a>
        {%- else -%}
          <a href="{{ routes.account_login_url }}"><strong>Giris yap</strong></a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="reborn-nav-wrap">
    <div class="container">
      {%- assign header_menu = linklists[section.settings.menu] -%}
      {%- if header_menu == blank -%}
        {%- assign header_menu = linklists['main-menu'] -%}
      {%- endif -%}
      {%- assign categories_label = section.settings.categories_title | default: 'KATEGORILER' -%}
      {%- assign fixed_categories = 'Deniz & Plaj Malzemeleri::deniz-plaj-malzemeleri|Giyim::giyim|Canta::canta|Kartlik & Cuzdan::kartlik-cuzdan|Spor & Egzersiz::spor-egzersiz|Medikal Bandajlar::medikal-bandajlar|Masaj Aletleri::masaj-aletleri|Outdoor Urunler::outdoor-urunler|Oyun & Eglence::oyun-eglence|Tatil & Seyahat Urunleri::tatil-seyahat-urunleri|Pratik Organizer Urunler::pratik-organizer-urunler|Makyaj & Taki Organizeri::makyaj-taki-organizeri|Mousepad::mousepad|Telefon & Tablet Standi::telefon-tablet-standi|Aksesuar::aksesuar|Pet Shop::pet-shop|Waterproof Urunler::waterproof-urunler' | split: '|' -%}
      <nav class="reborn-nav" aria-label="Ana menu">
        <div class="reborn-nav__inner">
          <div class="reborn-categories">
            <button type="button" class="reborn-categories__trigger" aria-expanded="false">
              {{ categories_label }}
              <span aria-hidden="true">&#9776;</span>
            </button>
            <div class="reborn-categories__panel">
              <ul>
                {%- for category_item in fixed_categories -%}
                  {%- assign category_parts = category_item | split: '::' -%}
                  {%- assign category_title = category_parts[0] -%}
                  {%- assign category_handle = category_parts[1] | default: category_title | handleize -%}
                  {%- assign category_collection = collections[category_handle] -%}
                  {%- if category_collection != blank -%}
                    {%- assign category_url = category_collection.url -%}
                  {%- else -%}
                    {%- assign category_query = category_title | url_encode -%}
                    {%- assign category_url = routes.search_url | append: '?type=product&q=' | append: category_query -%}
                  {%- endif -%}
                  <li>
                    <a href="{{ category_url }}">
                      <span>{{ category_title | escape }}</span>
                      <span aria-hidden="true">&#8250;</span>
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
          <ul class="reborn-nav__links">
          {%- for link in header_menu.links -%}
            <li>
              <a href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
          </ul>
        </div>
      </nav>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reborn Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "750 TL ve uzeri alisverislerde ucretsiz kargo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu"
    },
    {
      "type": "text",
      "id": "categories_title",
      "label": "Categories title",
      "default": "KATEGORILER"
    },
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "Categories menu"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Urun, kategori veya marka ara"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+90 555 880 2818"
    }
  ]
}
{% endschema %}
