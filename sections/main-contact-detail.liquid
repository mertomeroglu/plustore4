{{ 'main-contact-detail.css' | asset_url | stylesheet_tag }}

<div class="contact-detail__layout">
  <div class="container">
    <div class="contact-detail__container">
      {%- if section.settings.title != blank -%}
        <div class="contact-template__title">
          <h2 class="contact-title">
            {{ section.settings.title }}
          </h2>
        </div>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="contact-detail__content row">
		  {% for block in section.blocks %}
            <div class="contact-detail__item col-{{ block.settings.col }} col-sm-{{ block.settings.col_sm }} col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
              {% if block.settings.icon %}
                <div class="contact-detail__item-icon">
                  <img class="icon"
                       srcset="{% render 'bgset', image: block.settings.icon %}"
                       src="{% render 'srcset', image: block.settings.icon %}"
                       alt="{{ block.settings.icon.alt | escape }}"
                       loading="lazy"
                       width="{{ block.settings.icon.width }}"
                       height="{{ block.settings.icon.height }}"
                       >  
                </div>
              {% endif %}
              <div class="contact-detail__item-content">
                {%- if block.settings.heading != blank -%}
                  <p class="contact-detail__item-heading">
                    {{ block.settings.heading }}
                  </p>
                {%- endif -%}
                {%- if block.settings.subtext != blank -%}
                  <div class="contact-detail__item-caption">
                    {{ block.settings.subtext }}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {% endfor %}	
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
