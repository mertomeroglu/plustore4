<!-- /sections/index-best-sellers.liquid -->
<div data-section-type="best-sellers-section" class="spaced-section {{ section.settings.display }}" data-section-name="best-sellers-section">
  <div class="container">
    <div class="best-sellers__container {% unless section.settings.daily_enable %}best-sellers__full{% endunless %}">
      {%- if section.settings.daily_enable -%}
        <div class="best-sellers__daily">
          {%- if section.settings.daily_title != blank -%}
            <div class="box-divider title-daily_{{ section.id }}">
              {%- if section.settings.daily_icon != blank -%}              
              <div class="group-icon">              
              {%- endif -%}              
              {%- if section.settings.daily_icon != blank -%}
                <img class="box-icon"
                     srcset="{% render 'bgset', image: section.settings.daily_icon %}"
               		 src="{% render 'srcset', image: section.settings.daily_icon %}"
                     alt="{{ section.settings.daily_icon.alt | escape }}"
                     loading="lazy"
                     width="{{ section.settings.daily_icon.width }}"
                     height="{{ section.settings.daily_icon.height }}"
                     >
              {%- endif -%}
              <h2 class="box-title">{{ section.settings.daily_title }}</h2>
              {%- if section.settings.daily_icon != blank -%}                           
              </div>
              {%- endif -%} 
              {%- if section.settings.daily_dealtime != blank -%}
                <countdown-component class="countdown countdown_{{ section.id }}">
                  <div class="countdown-timer" data-timer data-timervalue="{{ section.settings.daily_dealtime }}" data-timer-languages='{"days": "", "hours": "", "minutes": "", "seconds": ""}' data-timer-point=':'>              
                  </div>
                </countdown-component>
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="best-sellers__daily-product">
            {%- liquid
              assign product = all_products[section.settings.daily_product]
              unless product == empty
                render 'index-product-item', product: product
              else
                render 'index-product-item-sample'
              endunless
             -%}
          </div>
        </div>
      {%- endif -%}
      {%- if section.settings.best_enable -%}
        <div class="best-sellers__best">
          {%- if section.settings.best_title != blank -%}
            <div class="box-divider title-best_{{ section.id }}">
              {%- if section.settings.best_icon != blank -%}
              <div class="group-icon">
              {%- endif -%}
              {%- if section.settings.best_icon != blank -%}
                <img class="box-icon"
                     srcset="{% render 'bgset', image: section.settings.best_icon %}"
               		 src="{% render 'srcset', image: section.settings.best_icon %}"
                     alt="{{ section.settings.best_icon.alt | escape }}"
                     loading="lazy"
                     width="{{ section.settings.best_icon.width }}"
                     height="{{ section.settings.best_icon.height }}"
                     >
              {%- endif -%}
              <h2 class="box-title">{{ section.settings.best_title }}</h2>
              {%- if section.settings.best_icon != blank -%}
              </div>
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="best-sellers__best-product">
            <div class="best-product__content row row-cols-{{ section.settings.col }} row-cols-sm-{{ section.settings.col_sm }} row-cols-md-{{ section.settings.col_md }} row-cols-lg-{{ section.settings.col_lg }} row-cols-xl-{{ section.settings.col_xl }} row-cols-xxl-{{ section.settings.col_xxl }}">
              {%- for product in collections[section.settings.best_collection].products limit: section.settings.limit -%}
                <div class="product-item__content col">
                  {%- render 'index-product-item-list', product: product -%}
                </div>
              {%- else -%}
                {% for i in (1..section.settings.limit) %}
              	  <div class="product-item__content col">
                    {%- render 'index-product-item-list-sample' -%}
                  </div>
                {% endfor %}
              {%- endfor -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
{% style %}
  .title-daily_{{ section.id }}:after{
    background-color: {{ section.settings.daily_color }};
  } 
  .title-best_{{ section.id }}:after{
    background-color: {{ section.settings.best_color }};
  } 
  .countdown_{{ section.id }}{
    color: {{ section.settings.daily_color }};
  }
{% endstyle %}
