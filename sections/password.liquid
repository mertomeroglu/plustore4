{%- layout 'password' -%}
<div class="password__content" {% if section.settings.background %}style="background-image:url({{ section.settings.background | img_url: 'master'}})"{% endif %}>
  <div class="container">
    {%- if section.settings.title != blank -%}
      <h2 class="password__content-title">
        {{ section.settings.title }}
      </h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="password__content-newsletter">
        {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'paragraph' -%}
            <div class="newsletter__subheading" {{ block.shopify_attributes }}>{{ block.settings.paragraph }}</div>
          {%- when '@app' -%}
            {% render block %}
          {%- when 'email_form' -%}
            <div {{ block.shopify_attributes }}>
              {% form 'customer', class: 'newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="newsletter-form__field-wrapper">
                  <div class="field">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="Newsletter-error--{{ section.id }}"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="Newsletter-success--{{ section.id }}"
                      {% endif %}
                      placeholder="{{ block.settings.placeholder }}"
                      required
                    >
                    <label class="field__label" for="NewsletterForm--{{ section.id }}">
                      {{ block.settings.placeholder }}
                    </label>
                  </div>
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
                  {%- endif -%}
                </div>
                {%- if block.settings.action != blank -%}
                  <button type="submit" class="newsletter__button button" name="commit">
                    {{ block.settings.action }}
                  </button>
                {%- endif -%}
                {%- if form.posted_successfully? -%}
                  <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</h3>
                {%- endif -%}
              {% endform %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.timer != blank -%}
      <countdown-password-component class="countdown countdown_{{ section.id }}">
        <div class="countdown-timer" data-timer data-timervalue="{{ section.settings.timer }}" data-timer-languages='{"days": "{{ section.settings.day }}", "hours": "{{ section.settings.hour }}", "minutes": "{{ section.settings.minute }}", "seconds": "{{ section.settings.second }}"}' data-timer-point=''>
        </div>
      </countdown-password-component>
      <script type="text/javascript">
        class CountdownPassword extends HTMLElement {
          constructor() {
            super();
            this.timer = this.querySelector('[data-timer]');
            const timervalue = this.timer.dataset.timervalue;
            const languages = JSON.parse(this.timer.dataset.timerLanguages);
            const point = this.timer.dataset.timerPoint;
            let day = '',
                hour = '',
                minute = '',
                second = '',
                htmlPoint = '';
            if (languages.days !== '') day = `<span class="language">${languages['days']}</span>`;
            if (languages.hours !== '') hour = `<span class="language">${languages['hours']}</span>`;
            if (languages.minutes !== '') minute = `<span class="language">${languages['minutes']}</span>`;
            if (languages.seconds !== '') second = `<span class="language">${languages['seconds']}</span>`;
            if (point !== '') htmlPoint = `<span class="point">${point}</span>`;
            $(this.timer).countdown(timervalue, (event) => {
              const $this = $(event.currentTarget);
              $this.html(event.strftime(`<div class='timer'><div class='timer-item'><span class='number'>%D</span>${day}${htmlPoint}</div><div class='timer-item'><span class='number'>%H</span>${hour}${htmlPoint}</div><div class='timer-item'><span class='number'>%M</span>${minute}${htmlPoint}</div><div class='timer-item'><span class='number'>%S</span>${second}</div></div>`));
            });
          }
        }

        customElements.define('countdown-password-component', CountdownPassword);
      </script>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "Password content",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "We are coming soon"
    },
    {
      "type": "text",
      "id": "timer",
      "label": "Timer",
      "default": "2021/12/06 00:00:00",
      "info":"Syntax YYYY/MM/DD HH:MM:SS"
    },
    {
      "type": "text",
      "id": "day",
      "label": "Day",
      "default": "Days"
    },
    {
      "type": "text",
      "id": "hour",
      "label": "Hour",
      "default": "Hours"
    },
    {
      "type": "text",
      "id": "minute",
      "label": "Minute",
      "default": "Minutes"
    },
    {
      "type": "text",
      "id": "second",
      "label": "Second",
      "default": "Seconds"
    },
    {
      "type": "image_picker",
      "id": "background",
      "label": "Background"
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "paragraph",
		  "label": "Description",
          "default": "<p>Be the first to know about new collections and exclusive offers.</p>"
        }
      ]
    },
    {
      "type": "email_form",
      "name": "Email form",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "placeholder",
		  "label": "Placeholder",
          "default": "Your email"
        },
		{
          "type": "text",
          "id": "action",
		  "label": "Action text",
          "default": "Sign Up"
        }
      ]
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}