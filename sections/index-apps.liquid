<div data-section-type="apps-section" class="spaced-section {{ section.settings.display }}" data-section-name="apps-section">
  <div class="{{ section.settings.layout }}">
    <div class="apps__container row">
      {%- for block in section.blocks -%}
        {% render block %}
      {%- endfor -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Apps",
  "tag": "section",
  "class": "index-apps",
  "settings": [
    {
      "type": "select",
      "id": "display",
      "label": "Display on",
      "options": [
        {
          "value": "",
          "label": "Desktop & Mobile"
        },
        {
          "value": "d-none d-md-block",
          "label": "Desktop only"
        },
        {
          "value": "d-block d-md-none",
          "label": "Mobile only"
        }
      ],
      "default": ""
    },
	{
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "container-fluid",
          "label": "Full width"
        }
      ],
      "default": "container"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Apps",
      "category": "Advanced"
    }
  ]
}
{% endschema %}
