<div id="cart-modal-data-total">{{ cart.total_price | money_with_currency }}</div>
<div id="cart-modal-data-count">{{ 'general.cart.view_count' | t: count: cart.item_count }}</div>
<div id="cart-modal-data-product">
  {%- if cart != empty -%}
    {%- for item in cart.items -%}
      <div id="cart-modal-data-product-{{ item.id }}">
        <div class="cart-modal__content-product">
          {% if item.image %}
            <img class="cart-modal-product__image"
              src="{{ item.image | img_url: '140x' }}"
              alt="{{ item.image.alt | escape }}"
              width="70"
              height="{{ 70 | divided_by: item.image.aspect_ratio | ceil }}"
              loading="lazy"
            >
          {% endif %}
          <div class="cart-modal-product__info">
            <h3 class="cart-modal-product__name h4">{{ item.product.title | escape }}</h3>
            {%- unless item.product.has_only_default_variant -%}
              <dl>
                {%- for option in item.options_with_values -%}
                  <div class="cart-modal-product__option h4">
                    <dt>{{ option.name }}: </dt>
                    <dd>{{ option.value }}</dd>
                  </div>
                {%- endfor -%}
              </dl>
            {%- endunless -%}
            <div class="cart-modal-product__price">
              {%- if item.original_price != item.final_price -%}
              <dl class="cart-item__discounted-prices">
                <dt class="visually-hidden">
                  {{ 'products.product.price.regular_price' | t }}
                </dt>
                <dd>
                  <s class="cart-item__old-price price">
                    {{ item.original_price | money }}
                  </s>
                </dd>
                <dt class="visually-hidden">
                  {{ 'products.product.price.sale_price' | t }}
                </dt>
                <dd class="price">
                  {{ item.final_price | money }}
                </dd>
              </dl>
              {%- else -%}
              <span class="price">
                {{ item.original_price | money }}
              </span>
              {%- endif -%}
            </div>
            <div class="cart-modal-product__qty">
              {{ 'sections.cart.headings.qty' | t }}: <span id="cart-modal-product__qty-{{ item.id }}" class="cart-modal-product__qty-number">{{ item.quantity }}</span>
            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  {%- endif -%}
</div>