<!-- /sections/index-collection-slider.liquid -->
<div data-section-type="collection-slider-section" class="spaced-section {{ section.settings.display }}" data-section-name="collection-slider-section">
  <div class="container">
    <div class="collection-slider__container">
      {%- if section.settings.title != blank or section.settings.action != blank -%}
        <div class="box-divider title-{{ section.id }}">
          {%- if section.settings.icon != blank -%}
          <div class="group-icon"> 
            <img class="box-icon"
                 srcset="{% render 'bgset', image: section.settings.icon %}"
                 src="{% render 'srcset', image: section.settings.icon %}"
                 alt="{{ section.settings.icon.alt | escape }}"
                 loading="lazy"
                 width="{{ section.settings.icon.width }}"
                 height="{{ section.settings.icon.height }}"
                 >
          {%- endif -%}
          {%- if section.settings.title != blank -%}
          <h2 class="box-title">{{ section.settings.title }}</h2>
          {%- endif -%}          
          {%- if section.settings.icon != blank -%}         
          </div>
          {%- if section.settings.action != blank -%}
          <a href="{{ collections[section.settings.collection].url }}" class="box-action">{{ section.settings.action }}</a>
          {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="collection-slider__content">
        <slider-component class="collection__slider">
          <div class="carousel" data-carousel-param='{"loop": "true", "effect": "{{ section.settings.effect }}", "autoplay": "{{ section.settings.autoplay }}", "autoplaySpeed": "{{ section.settings.autoplay_speed }}", "space": "{{ section.settings.space }}", "col": "{{ section.settings.col }}", "col_sm": "{{ section.settings.col_sm }}", "col_md": "{{ section.settings.col_md }}", "col_lg": "{{ section.settings.col_lg }}", "col_xl": "{{ section.settings.col_xl }}", "col_xxl": "{{ section.settings.col_xxl }}", "row": "1"}' data-carousel>
            <div class="carousel-wrapper carousel-{{ section.settings.navigation_position }}">
              <div class="swiper-container" data-carousel-container>
                <div class="swiper-wrapper row row-cols-{{ section.settings.col }} row-cols-sm-{{ section.settings.col_sm }} row-cols-md-{{ section.settings.col_md }} row-cols-lg-{{ section.settings.col_lg }} row-cols-xl-{{ section.settings.col_xl }} row-cols-xxl-{{ section.settings.col_xxl }}">
                  {%- for product in collections[section.settings.collection].products limit: section.settings.limit -%}
                    <div class="swiper-slide col product-item__content" data-carousel-item>
                      {%- render 'index-product-item', product: product -%}
                    </div>
                  {%- else -%}
                    {% for i in (1..section.settings.limit) %}
                      <div class="swiper-slide col product-item__content" data-carousel-item>
                        {%- render 'index-product-item-sample' -%}
                      </div>
                    {% endfor %}
                  {%- endfor -%}
                </div>
              </div>
              {%- if section.settings.navigation -%}
              <div class="carousel-navigation carousel-nav-prev" data-carousel-nav-prev><i class="cs-icon icon-ios-arrow-left"></i></div>
              <div class="carousel-navigation carousel-nav-next" data-carousel-nav-next><i class="cs-icon icon-ios-arrow-right"></i></div>
              {%- endif -%}
            </div>
            {%- if section.settings.pagination -%}
            <div class="carousel-pagination" data-carousel-pagination></div>
            {%- endif -%}
          </div>
        </slider-component>
      </div>
    </div>
  </div>
</div>
{% style %}
  .title-{{ section.id }}:after{
    background-color: {{ section.settings.color }};
  }
{% endstyle %}
