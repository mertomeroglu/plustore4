    },
    {
      "type": "checkbox",
      "id": "article_share",
      "label": "Enable social sharing",
      "default": true
    },
	{
      "type": "checkbox",
      "id": "article_tags",
      "label": "Enable tags",
      "default": true
    },
	{
      "type": "header",
      "content": "Related article"
