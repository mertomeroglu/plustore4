{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-accordion.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<div class="bottom-footer bottom-footer--premium">
  <div class="container">
    <div class="bottom-footer__content">
      {%- if section.blocks.size > 0 -%}
        <div class="bottom-footer__top">
          <accordion-component data-accordion-parent="true" class="row">
            {%- for block in section.blocks -%}
              {%- if block.type == 'link_list' -%}
                <div class="footer__linklist col-12 col-sm-12 col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
                  <div class="footer__linklist-accordion accordion d-block d-lg-none" {{ block.shopify_attributes }}>
                    <h4 class="accordion__title">
                      <span>{{ block.settings.heading }}</span>
                    </h4>
                    <div class="footer-block__details-content accordion__content">
                      {%- if block.settings.linklist != blank -%}
                        <ul class="list-unstyled">
                          {%- for link in block.settings.linklist.links -%}
                          <li>
                            <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}">
                              {{ link.title }}
                            </a>
                          </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>
                  </div>
                  <div class="footer__linklist-menu d-none d-lg-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.heading != blank -%}
                      <h2 class="footer-block__heading">{{- block.settings.heading | escape -}}</h2>
                    {%- endif -%}
                    {%- if block.settings.linklist != blank -%}
                      <ul class="footer-block__details-content list-unstyled">
                        {%- for link in block.settings.linklist.links -%}
                          <li>
                            <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}">
                              {{ link.title }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              {%- else -%}
                <div class="footer__newsletter_social col-12 col-sm-12 col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
                  <div class="footer__newsletter-accordion accordion d-block d-lg-none" {{ block.shopify_attributes }}>
                    <h4 class="accordion__title">
                      <span>{{ block.settings.heading }}</span>
                    </h4>
                    <div class="accordion__content footer-block__details-content">
                      {%- form 'customer', id: 'ContactFooterMobile', class: 'footer__newsletter newsletter-form' -%}
                          {%- if block.settings.subtext != blank -%}
                            <p class="newsletter-form__subtext">{{- block.settings.subtext | escape -}}</p>
                          {%- endif -%}
                          {%- if form.posted_successfully? -%}
                            <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>{% render 'icon-success' %}{{ 'newsletter.success' | t }}</h3>
                          {%- endif -%}
                          <input type="hidden" name="contact[tags]" value="newsletter">
                          <div class="newsletter-form__field-wrapper">
                            <div class="field">
                              <input
                                id="NewsletterForm--{{ section.id }}-Mobile"
                                type="email"
                                name="contact[email]"
                                class="field__input"
                                value="{{ form.email }}"
                                aria-required="true"
                                autocorrect="off"
                                autocapitalize="off"
                                autocomplete="email"
                                {% if form.errors %}
                                  autofocus
                                  aria-invalid="true"
                                  aria-describedby="ContactFooter-error"
                                {% elsif form.posted_successfully? %}
                                  aria-describedby="ContactFooter-success"
                                {% endif %}
                                placeholder="{{ 'newsletter.label' | t }}"
                                required
                              >
                              <label class="field__label" for="NewsletterForm--{{ section.id }}-Mobile">
                                {{ 'newsletter.label' | t }}
                              </label>
                            </div>
                            {%- if form.errors -%}
                              <small class="newsletter-form__message form__message" id="ContactFooter-error-Mobile">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
                            {%- endif -%}
                            <button type="submit" class="button button--secondary newsletter-form__button" name="commit" id="Subscribe-Mobile">
                              {{ 'newsletter.button_label' | t }}
                            </button>
                          </div>
                        {%- endform -%}
                        {%- if block.settings.show_social -%}
                          <div class="footer__list-social">
                            {%- if block.settings.social_heading != blank -%}
                              <h2 class="h4 accordion__title">{{ block.settings.social_heading | escape }}</h2>
                            {%- endif -%}
                            {%- include 'social' -%}
                          </div>
                        {%- endif -%}
                    </div>
                  </div>
                  <div class="footer__newsletter_social d-none d-lg-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.heading != blank -%}
                      <h2 class="footer-block__heading">{{- block.settings.heading | escape -}}</h2>
                    {%- endif -%}
                    <div class="footer-block__details-content">
                      {%- form 'customer', id: 'ContactFooterDesktop', class: 'footer__newsletter newsletter-form' -%}
                        {%- if block.settings.subtext != blank -%}
                          <p class="newsletter-form__subtext">{{- block.settings.subtext | escape -}}</p>
                        {%- endif -%}
                        {%- if form.posted_successfully? -%}
                          <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>{% render 'icon-success' %}{{ 'newsletter.success' | t }}</h3>
                        {%- endif -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="newsletter-form__field-wrapper">
                          <div class="field">
                            <input
                                   id="NewsletterForm--{{ section.id }}-Desktop"
                                   type="email"
                                   name="contact[email]"
                                   class="field__input"
                                   value="{{ form.email }}"
                                   aria-required="true"
                                   autocorrect="off"
                                   autocapitalize="off"
                                   autocomplete="email"
                                   {% if form.errors %}
                                   autofocus
                                   aria-invalid="true"
                                   aria-describedby="ContactFooter-error"
                                   {% elsif form.posted_successfully? %}
                                   aria-describedby="ContactFooter-success"
                                   {% endif %}
                                   placeholder="{{ 'newsletter.label' | t }}"
                                   required
                                   >
                            <label class="field__label" for="NewsletterForm--{{ section.id }}-Desktop">
                              {{ 'newsletter.label' | t }}
                            </label>
                          </div>
                          {%- if form.errors -%}
                          <small class="newsletter-form__message form__message" id="ContactFooter-error-Desktop">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
                          {%- endif -%}
                          <button type="submit" class="button button--secondary newsletter-form__button" name="commit" id="Subscribe-Desktop">
                            {{ 'newsletter.button_label' | t }}
                          </button>
                        </div>                      
                      {%- endform -%}
                      {%- if block.settings.show_social -%}
                        <div class="footer__list-social">
                          {%- if block.settings.social_heading != blank -%}
                            <h2 class="footer-block__heading">{{ block.settings.social_heading | escape }}</h2>
                          {%- endif -%}
                          {%- include 'social' -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </accordion-component>
        </div>
      {%- endif -%}
      {%- if section.settings.menu_enable and section.settings.menu_linklist != blank -%}
        <div class="footer__menu col-12">
          <ul class="list-menu--inline no-bullet clearfix">
            {%- for link in section.settings.menu_linklist.links -%}
            <li>
              <a href="{{ link.url }}" class="list-menu__item{% if link.active %} list-menu__item--active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>
                {{ link.title | escape }}
              </a>
            </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div class="footer__copyright col-12">
		{{ 'sections.footer.copyright' | t }} &copy; {{ 'now' | date: "%Y" }} {{ shop.name | link_to: '/' }}
      </div>
      {%- if section.settings.payment_enable -%}
        <div class="footer__payment col-12">
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      {%- if section.settings.keywords_enable and section.settings.keywords_linklist != blank -%}
        <div class="footer__keywords col-12">
          <accordion-component data-accordion-parent="false">
            <div class="footer__linklist-accordion accordion d-block d-lg-none">
              <h4 class="accordion__title">
                <span>{{ section.settings.keywords_heading }}</span>
              </h4>
              <div class="footer-block__details-content accordion__content">
                {%- if section.settings.keywords_linklist != blank -%}
                  <ul class="list-unstyled">
                    {%- for link in section.settings.keywords_linklist.links -%}
                    <li>
                      <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link">
                        {{ link.title }}
                      </a>
                    </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            </div>
          </accordion-component>
          <div class="footer__keywords-menu d-none d-lg-block">
            {%- if section.settings.keywords_heading != blank -%}
              <h2 class="keywords__heading">{{- section.settings.keywords_heading | escape -}}</h2>
            {%- endif -%}
            {%- if section.settings.keywords_linklist != blank -%}
              <ul class="list-menu--inline no-bullet clearfix">
                {%- for link in section.settings.keywords_linklist.links -%}
                <li>
                  <a href="{{ link.url }}" class="list-menu__item">
                    {{ link.title | escape }}
                  </a>
                </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>  
  </div>
</div>
