<!-- /sections/index-banner-grid.liquid -->
{%- if section.blocks.size > 0 -%}
<div data-section-type="banner-section" class="spaced-section {{ section.settings.display }}" data-section-name="banner-section">
  <div class="container">
    <div class="banner-grid__container row">
      {%- assign fixed_aspect_ratio = false -%}
      {%- unless section.settings.image_size == 'natural' -%}
        {%- assign fixed_aspect_ratio = true -%}
      {%- endunless -%}
      {%- for block in section.blocks -%}
        <div class="col-{{ block.settings.col }} col-sm-{{ block.settings.col_sm }} col-md-{{ block.settings.col_md }} col-lg-{{ block.settings.col_lg }} col-xl-{{ block.settings.col_xl }} col-xxl-{{ block.settings.col_xxl }}">
          {%- if block.type == 'one_banner' -%}
            <div class="banner-grid__item banner-grid__caption-{{ block.settings.style }} banner-grid__caption-{{ block.settings.position }}">
              <a href="{{ block.settings.link }}" class="banner-grid__link">
                <span class="visually-hidden">{%- if block.settings.image.alt != blank -%}{{ section.settings.image.alt }} {%- else -%}banner grid{%- endif-%}</span>
                {%- if block.settings.image -%}
                  {%- assign preview_img = block.settings.image -%}
                  <div class="lazy-bg product-item__image {% if fixed_aspect_ratio %}image-ratio--{{ section.settings.image_size }}{% endif %}" {% unless fixed_aspect_ratio %}style="padding-bottom: {{ 100 | divided_by: preview_img.aspect_ratio }}%;"{% endunless %}>
                    <img {% render 'lazyload', preview_img: preview_img  %} />
                    <span class="data-lazy-loading"></span>
                  </div>
                {%- else -%}
                  <img class="product-item__image lazyload"
                       src="{{ '283x388.png' | asset_url }}"
                       loading="lazy">
                {%- endif -%}
              </a>
              <div class="banner-grid__caption">
                {%- if block.settings.title != blank -%}
                  <p class="banner-grid__title">{{ block.settings.title }}</p>
                {%- endif -%}
                {%- if block.settings.subtitle != blank -%}
                  <p class="banner-grid__subtitle">{{ block.settings.subtitle }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- else -%}
            <div class="banner-grid__item-two">
              {%- for i in (1..2) -%}
                {%- capture image -%}image_{{ i }}{%- endcapture -%}
                {%- capture title -%}title_{{ i }}{%- endcapture -%}
                {%- capture subtitle -%}subtitle_{{ i }}{%- endcapture -%}
                {%- capture link -%}link_{{ i }}{%- endcapture -%}
                {%- capture style -%}style_{{ i }}{%- endcapture -%}
                {%- capture position -%}position_{{ i }}{%- endcapture -%}
                <div class="banner-grid__item banner-grid__caption-{{ block.settings[style] }} banner-grid__caption-{{ block.settings[position] }}">
                  <a href="{{ block.settings[link] }}" class="banner-grid__link">
                    <span class="visually-hidden">{%- if block.settings[image].alt != blank -%}{{ section.settings[image].alt }} {%- else -%}banner grid{%- endif-%}</span>
                    {%- if block.settings[image] -%}
                      {%- assign preview_img = block.settings[image] -%}
                      <div class="lazy-bg product-item__image {% if fixed_aspect_ratio %}image-ratio--{{ section.settings.image_size }}{% endif %}" {% unless fixed_aspect_ratio %}style="padding-bottom: {{ 100 | divided_by: preview_img.aspect_ratio }}%;"{% endunless %}>
                        <img {% render 'lazyload', preview_img: preview_img  %} />
                        <span class="data-lazy-loading"></span>
                      </div>
                    {%- else -%}
                      <img class="product-item__image lazyload"
                           src="{{ '283x188.png' | asset_url }}"
                           loading="lazy">
                    {%- endif -%}
                  </a>
                  <div class="banner-grid__caption">
                    {%- if block.settings[title] != blank -%}
                      <p class="banner-grid__title">{{ block.settings[title] }}</p>
                    {%- endif -%}
                    {%- if block.settings[subtitle] != blank -%}
                      <p class="banner-grid__subtitle">{{ block.settings[subtitle] }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}
