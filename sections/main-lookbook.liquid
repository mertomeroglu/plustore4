{%- if section.blocks.size > 0 -%}
{{ 'main-lookbook.css' | asset_url | stylesheet_tag }}
{{ 'photoswipe.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'photoswipe.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'lookbook-component.js' | asset_url }}" defer="defer"></script>

<div class="main-lookbook__layout">
  <div class="container">
    <div class="main-lookbook__content row">
      {%- for block in section.blocks -%}
      	<div class="main-lookbook__item col-12 col-md-6">
          <lookbook-component>
            {%- for i in (1..3) -%}
              {%- capture image -%}lookbook_image_{{i}}{%- endcapture -%}
              {%- if block.settings[image] -%}
                <div class="lookbook-item__image {%- unless i == 1 %} hidden{% endunless -%}">
                  <div class="lazy-bg lookbook-item__image-zoom" style="padding-bottom: {{ 100 | divided_by: block.settings[image].aspect_ratio }}%;"
                    data-sizes="auto"
                    data-aspectratio="{{ block.settings[image].aspect_ratio }}"
                    data-parent-fit="cover"
                    data-src="{{ block.settings[image] | img_url: 'master' }}" 
                    data-width="{{ block.settings[image].width }}"
                    data-height="{{ block.settings[image].height }}"
                    >
                    {%- assign preview_img = block.settings[image] -%}
                    <img {% render 'lazyload', preview_img: preview_img  %} />
                    <span class="data-lazy-loading"></span>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </lookbook-component>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
<div class="pswp" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="pswp__bg"></div>
  <div class="pswp__scroll-wrap">
    <div class="pswp__container">
      <div class="pswp__item"></div>
      <div class="pswp__item"></div>
      <div class="pswp__item"></div>
    </div>
    <div class="pswp__ui pswp__ui--hidden">
      <div class="pswp__top-bar">
        <div class="pswp__counter"></div>
        <button class="pswp__button pswp__button--close" title="Close (Esc)"></button>
        <button class="pswp__button pswp__button--share" title="Share"></button>
        <button class="pswp__button pswp__button--fs" title="Toggle fullscreen"></button>
        <button class="pswp__button pswp__button--zoom" title="Zoom in/out"></button>
        <div class="pswp__preloader">
          <div class="pswp__preloader__icn">
            <div class="pswp__preloader__cut">
              <div class="pswp__preloader__donut"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="pswp__share-modal pswp__share-modal--hidden pswp__single-tap">
        <div class="pswp__share-tooltip"></div> 
      </div>
      <button class="pswp__button pswp__button--arrow--left" title="Previous (arrow left)">
      </button>
      <button class="pswp__button pswp__button--arrow--right" title="Next (arrow right)">
      </button>
      <div class="pswp__caption">
        <div class="pswp__caption__center"></div>
      </div>
    </div>
  </div>
</div>
{%- endif -%}
{% schema %}
{
  "name": "Lookbook",
  "class": "main-lookbook",
  "blocks": [
    {
      "type": "item",
      "name": "Lookbook Gallery",
      "settings": [
        {
          "type": "image_picker",
          "id": "lookbook_image_1",
          "label": "Upload image 1"
        },
        {
          "type": "image_picker",
          "id": "lookbook_image_2",
          "label": "Upload image 2"
        },
        {
          "type": "image_picker",
          "id": "lookbook_image_3",
          "label": "Upload image 3"
        }
      ]
    }
  ]
}
{% endschema %}