{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

<noscript>{{ 'section-main-page.css' | asset_url | stylesheet_tag }}</noscript>

<div class="page-template__layout">
  <div class="container">
    <h1 class="main-page-title page-title h0 {% unless section.settings.title %}hide{% endunless %}">
      {{ page.title | escape }}
    </h1>
    {% if section.settings.content %}
      <div class="main-page--content">
        {{ page.content }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
	{
      "type": "checkbox",
      "id": "title",
      "label": "Enable title",
      "default": true
    },
	{
      "type": "checkbox",
      "id": "content",
      "label": "Enable content",
      "default": true
    }
  ]
}
{% endschema %}
