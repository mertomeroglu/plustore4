{% doc %}
  @prompt
    1 den fazla video ekleyebileceğim bir banner alanı oluştur
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multi-video-banner-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-multi-video-banner__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-multi-video-banner__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .ai-multi-video-banner__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-multi-video-banner__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-multi-video-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 2;
  }

  .ai-multi-video-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 3;
    width: 90%;
    max-width: 800px;
  }

  .ai-multi-video-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-multi-video-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
  }

  .ai-multi-video-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-multi-video-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-multi-video-banner__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 4;
  }

  .ai-multi-video-banner__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-multi-video-banner__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-multi-video-banner__dot-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 0.8);
  }

  .ai-multi-video-banner__arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
  }

  .ai-multi-video-banner__arrow-{{ ai_gen_id }} {
    background-color: rgba(0, 0, 0, 0.5);
    color: #ffffff;
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-multi-video-banner__arrow-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.8);
  }

  .ai-multi-video-banner__arrow--prev-{{ ai_gen_id }} {
    left: 24px;
  }

  .ai-multi-video-banner__arrow--next-{{ ai_gen_id }} {
    right: 24px;
  }

  .ai-multi-video-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
    font-size: 14px;
    border-radius: 4px;
    text-align: center;
    z-index: 5;
  }

  @media screen and (max-width: 749px) {
    .ai-multi-video-banner__container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_banner_height }}px;
    }

    .ai-multi-video-banner__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-multi-video-banner__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.85);
    }

    .ai-multi-video-banner__arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-multi-video-banner__arrow--prev-{{ ai_gen_id }} {
      left: 12px;
    }

    .ai-multi-video-banner__arrow--next-{{ ai_gen_id }} {
      right: 12px;
    }
  }
{% endstyle %}

<multi-video-banner-{{ ai_gen_id }}
  class="ai-multi-video-banner-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-multi-video-banner__container-{{ ai_gen_id }}">
    {% liquid
      assign has_videos = false
      for i in (1..5)
        assign video_key = 'video_' | append: i
        if block.settings[video_key] != blank
          assign has_videos = true
          break
        endif
      endfor
    %}

    {% for i in (1..5) %}
      {% liquid
        assign video_key = 'video_' | append: i
        assign heading_key = 'heading_' | append: i
        assign text_key = 'text_' | append: i
        assign button_text_key = 'button_text_' | append: i
        assign button_link_key = 'button_link_' | append: i
        assign video = block.settings[video_key]
        assign heading = block.settings[heading_key]
        assign text = block.settings[text_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
      %}

      {% if video != blank %}
        <div
          class="ai-multi-video-banner__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
        >
          {{
            video
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              class: 'ai-multi-video-banner__video-' | append: ai_gen_id
          }}

          <div class="ai-multi-video-banner__overlay-{{ ai_gen_id }}"></div>

          {% if heading != blank or text != blank or button_text != blank %}
            <div class="ai-multi-video-banner__content-{{ ai_gen_id }}">
              {% if heading != blank %}
                <h2 class="ai-multi-video-banner__heading-{{ ai_gen_id }}">{{ heading }}</h2>
              {% endif %}

              {% if text != blank %}
                <div class="ai-multi-video-banner__text-{{ ai_gen_id }}">{{ text }}</div>
              {% endif %}

              {% if button_text != blank %}
                <a
                  href="{{ button_link | default: '#' }}"
                  class="ai-multi-video-banner__button-{{ ai_gen_id }}"
                >
                  {{ button_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

    {% unless has_videos %}
      <div class="ai-multi-video-banner__empty-state-{{ ai_gen_id }}">
        Başlamak için en az bir video ekleyin
      </div>
    {% endunless %}

    {% if has_videos and block.settings.show_arrows %}
      <div class="ai-multi-video-banner__arrows-{{ ai_gen_id }} ai-multi-video-banner__arrow--prev-{{ ai_gen_id }}">
        <button
          class="ai-multi-video-banner__arrow-{{ ai_gen_id }}"
          aria-label="Önceki video"
          data-direction="prev"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
      </div>

      <div class="ai-multi-video-banner__arrows-{{ ai_gen_id }} ai-multi-video-banner__arrow--next-{{ ai_gen_id }}">
        <button
          class="ai-multi-video-banner__arrow-{{ ai_gen_id }}"
          aria-label="Sonraki video"
          data-direction="next"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}

    {% if has_videos and block.settings.show_dots %}
      <div class="ai-multi-video-banner__controls-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign video = block.settings[video_key]
          %}
          {% if video != blank %}
            <button
              class="ai-multi-video-banner__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              aria-label="Video {{ forloop.index }}'e git"
              data-slide-index="{{ forloop.index0 }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</multi-video-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class MultiVideoBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-multi-video-banner__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-multi-video-banner__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('[data-direction="prev"]');
        this.nextButton = this.querySelector('[data-direction="next"]');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 5000;

        if (this.slides.length === 0) return;

        this.setupEventListeners();
        this.playCurrentVideo();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplay && this.slides.length > 1) {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.pauseCurrentVideo();

        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }

        this.playCurrentVideo();
      }

      goToNextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      goToPrevSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      playCurrentVideo() {
        const video = this.slides[this.currentSlide].querySelector('video');
        if (video) {
          video.play().catch(() => {});
        }
      }

      pauseCurrentVideo() {
        const video = this.slides[this.currentSlide].querySelector('video');
        if (video) {
          video.pause();
        }
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('multi-video-banner-{{ ai_gen_id }}', MultiVideoBanner{{ ai_gen_id }});
  })();
</script>

